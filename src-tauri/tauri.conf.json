{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashcards Maker",
  "version": "0.1.0",
  "identifier": "com.flashcards.maker",
  "build": {
    "beforeDevCommand": "pnpm.cmd dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flashcards Maker",
        "width": 1160,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
